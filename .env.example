# ── TestMW Browser Host — example configuration ──────────────────────────
# Copy to .env and fill in WORKER_TOKEN.

# TestMW relay address (defaults to production). wss:// on 443 — don't change
# without a reason.
RELAY_URL=wss://testmw.ru/relay/host

# Token that binds the agent to your account (get it in the TestMW dashboard).
# REQUIRED.
WORKER_TOKEN=

# Instance name shown in the dashboard (defaults to the machine hostname).
# HOST_NAME=my-staging-runner

# Transport: auto (WS→polling), ws, polling.
# TRANSPORT_MODE=auto

# ── Corporate network / VPN ──────────────────────────────────────────────
# The proxy is taken from the standard variables (like curl/git). Uncomment if
# needed:
# HTTPS_PROXY=http://proxy.corp.local:8080
# NO_PROXY=.internal,localhost
#
# TLS inspection (a MITM proxy with its own CA): add the corporate CA like this:
# NODE_EXTRA_CA_CERTS=/path/to/corp-ca.pem
# The agent does NOT pin certs — such networks work out of the box.

# LOG_LEVEL=info

# ── Browser ──────────────────────────────────────────────────────────────
# HEADLESS=true
# MAX_SESSIONS=4
# BROWSER_ARGS=
